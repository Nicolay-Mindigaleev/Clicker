<Window x:Class="Grathic_app_2._0.DeveloperConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:Grathic_app_2._0"
        mc:Ignorable="d"
        Title="DeveloperConsole" Height="450" Width="800">
        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Text="{Binding PlayerScore, StringFormat=Player clicks: {0}}" Margin="0,0,0,10"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Add clicks"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                <xctk:IntegerUpDown x:Name="NewClicksValue" Value="0" Height="30" Width="100"></xctk:IntegerUpDown>
                <Button Height="30" Width="80" Content="Add" Click="SetCLicksButton_click" Margin="5,0,0,0"></Button>
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Change power click level" Margin="0,10,0,0"/>
            <xctk:IntegerUpDown Grid.Row="2" Grid.Column="1" x:Name="PowerClicksLvlBox" Minimum="0" Maximum="15" Value="0" Height="30" Width="100" ValueChanged="PowerLevel_changed" Margin="0,10,0,0"></xctk:IntegerUpDown>
            
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Change auto click level" Margin="0,10,0,0"/>
            <xctk:IntegerUpDown Grid.Row="3" Grid.Column="1" x:Name="AutoClicksLvlBox" Minimum="0" Maximum="15" Value="0" Height="30" Width="100" ValueChanged="AutoLevel_changed" Margin="0,10,0,0"></xctk:IntegerUpDown>

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Change critical click level" Margin="0,10,0,0"/>
            <xctk:IntegerUpDown Grid.Row="4" Grid.Column="1" x:Name="CriticalClicksLvlBox" Minimum="0" Maximum="15" Value="0" Height="30" Width="100" ValueChanged="CriticalLevel_changed" Margin="0,10,0,0"></xctk:IntegerUpDown>

            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Change winner score" Margin="0,10,0,0"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                <xctk:IntegerUpDown x:Name="NewWinnerScore" Minimum="1" Maximum="10000000" Value="1000" Height="30" Width="100"></xctk:IntegerUpDown>
                <Button Height="30" Width="80" Content="Apply" Click="SetWinnerScore_click" Margin="5,0,0,0"></Button>
            </StackPanel>
            <Button Grid.Row="6" Grid.ColumnSpan="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="40" Width="100" Content="Close window" Click="CloseButton_click" Margin="10"></Button>
        </Grid>
         
</Window>