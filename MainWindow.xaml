<Window x:Class="Grathic_app_2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grathic_app_2._0"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
    <StackPanel Orientation="Horizontal">
        <TextBlock Text="Clicks count: "></TextBlock>
        <TextBlock Text="{Binding ClicksCount}"></TextBlock>
        <TextBlock x:Name="AutoClickPopup" Text="" 
            FontSize="16" FontWeight="Bold" 
            Foreground="LightGray"
            Opacity="0"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,5,0,0"/>
    </StackPanel>
    <TextBlock x:Name="CritPopup" 
            Text="CRIT!" 
            FontSize="20" FontWeight="Bold" 
            Foreground="Red"
            Opacity="0"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,150,0,0"/>
    <Button x:Name="MainButton" Content="Click" Height="40" Width="100" Click="mainButton_click"></Button>
    <Button x:Name="ShopButton" Content="Shop" Height="40" Width="100" IsEnabled="false" HorizontalAlignment="Right" Click="ShopButton_click"></Button>
    </Grid>
</Window>
