<Window x:Class="Grathic_app_2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grathic_app_2._0"
        mc:Ignorable="d"
        Title="Clicker The game" Height="450" Width="800"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
    <StackPanel Orientation="Horizontal" Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Clicks count: " FontSize="14" Foreground="Gray"></TextBlock>
        <TextBlock Text="{Binding ClicksCount}" FontSize="14" Foreground="#333" FontWeight="SemiBold"></TextBlock>
        <TextBlock x:Name="AutoClickPopup" Text="" 
            FontSize="16" FontWeight="Bold" 
            Foreground="LightGray"
            Opacity="0"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,5,0,0"/>
    </StackPanel>
    <TextBlock x:Name="CritPopup" 
            Text="CRIT!" 
            FontSize="20" FontWeight="Bold" 
            Foreground="Red"
            Opacity="0"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,150,0,0"/>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
    <Button x:Name="MainButton" Content="Click" Height="40" Width="100" Click="mainButton_click" Margin="0,0,50,0"></Button>
    <Button x:Name="ShopButton" Content="Shop" Height="40" Width="100" IsEnabled="false" Click="ShopButton_click"></Button>
    </StackPanel>
    <TextBlock x:Name="ComboText" 
            Text="{Binding ComboClick, StringFormat=+{0}}" 
            FontSize="14" FontWeight="Bold" 
            Foreground="#555555"
            HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0,0,0,150"
            Visibility="Hidden"/>
    </Grid>
</Window>
